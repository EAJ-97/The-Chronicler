# JWT secret used for signing authentication tokens.
# Generate one with: openssl rand -base64 48
# Keep this value stable — changing it logs out all users.
JWT_SECRET=replace-me-with-a-long-random-string

# Optional: emergency admin password reset from the login screen (POST /auth/recover-admin).
# Must be at least 16 characters. Generate with: openssl rand -hex 24
# Never commit a real value. Restart the app after setting.
# ADMIN_RECOVERY_TOKEN=

# Session recaps use Anthropic (Claude). Configure the API key in Admin → AI (stored in the database).
