# JWT secret used for signing authentication tokens.
# Generate one with: openssl rand -base64 48
# Keep this value stable — changing it logs out all users.
JWT_SECRET=replace-me-with-a-long-random-string

# Optional: Google Gemini API key for DM/admin “Generate with Gemini” sidebar icons only.
# Overrides the Admin → AI → Gemini key stored in the database. Get a key from Google AI Studio.
# GEMINI_API_KEY=
# Optional model override (default: gemini-2.5-flash-image). Must support image output.
# GEMINI_ICON_MODEL=gemini-2.5-flash-image
