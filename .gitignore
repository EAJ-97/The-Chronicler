# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output — generated by Docker at build time
frontend/dist/

# Runtime data — SQLite database / Docker volume symlinks (never commit user data)
data
data/
data-dev
data-dev/
*.db
*.sqlite

# Environment / secrets
.env
.env.*
!.env.example

# Dev files (local only, not tracked)
docker-compose.dev.yml
Dockerfile.dev

# AI / agent context (local only, not for public repo)
CONTEXT.md
roadmaps.md
plans/

# One-off release notes (used for GitHub release / chat paste only, not committed)
release-*-notes.txt
RELEASE_NOTES*.md

# Local docs (not tracked unless we explicitly add something worth shipping)
docs/

# Cursor IDE — ignore everything
.cursor/*

# OS / editor
.DS_Store
Thumbs.db
*.swp
